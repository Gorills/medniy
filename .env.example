# ================================================================
# Приложение
# ================================================================
APP_NAME=Medniy
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=http://localhost:8080

LOG_CHANNEL=stack

# ================================================================
# База данных (в Docker: хост = db)
# ================================================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=medniy
DB_USERNAME=medniy
DB_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME

# ================================================================
# Кэш / сессии (Redis: хост = cache)
# ================================================================
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_DRIVER=sync

REDIS_HOST=cache
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379

# ================================================================
# Почта
# ================================================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# ================================================================
# Docker (порты на хосте)
# ================================================================
HTTP_PORT=8080
# DB_EXTERNAL_PORT=33060

# ================================================================
# Google Maps (JavaScript API) — ключ из Google Cloud Console
# ================================================================
GOOGLE_MAPS_API_KEY=

# ================================================================
# Прочее (Laravel / фронт)
# ================================================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
